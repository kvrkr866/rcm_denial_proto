# ─────────────────────────────────────────────────────────────────────────────
# RCM Denial Management — Environment Variables
#
# Copy this file to .env and fill in the required values.
# Never commit .env to version control.
#
#   cp .env.example .env
# ─────────────────────────────────────────────────────────────────────────────


# ── Runtime environment ───────────────────────────────────────────────────────
# Options: development | staging | production
ENV=development


# ── OpenAI (REQUIRED for LLM pipeline) ───────────────────────────────────────
# Get your key at https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-key-here

# LLM model used for evidence_check_agent and response_agent
# Recommended: gpt-4o (best quality) or gpt-4o-mini (lower cost)
OPENAI_MODEL=gpt-4o

# Embedding model used for SOP RAG collections
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Max output tokens per LLM call (response_agent may need up to 4096)
OPENAI_MAX_TOKENS=4096

# LLM temperature: 0.0 = deterministic, higher = more creative
# Recommended: 0.1 for structured medical billing output
OPENAI_TEMPERATURE=0.1


# ── LangSmith tracing (optional) ─────────────────────────────────────────────
# Enable to trace all LangGraph runs in the LangSmith UI
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=ls-your-key-here
LANGCHAIN_PROJECT=rcm-denial-management


# ── ChromaDB / SOP RAG ───────────────────────────────────────────────────────
# Path where ChromaDB stores per-payer SOP vector collections
CHROMA_PERSIST_DIR=./data/chroma_db

# Fallback collection name used when no payer-specific collection exists
CHROMA_COLLECTION_NAME=sop_global

# Re-index a payer's collection when its SOP files are newer than the index
SOP_RAG_FRESHNESS_CHECK=true

# Minimum similarity score to include a RAG result (0.0–1.0)
# Lower = more results but less relevant; raise if getting noise
SOP_MIN_RELEVANCE_SCORE=0.3

# When true: process-batch logs a WARNING for payers without SOP collections
# Does NOT block the batch — claims fall back to keyword search
SOP_PIPELINE_STRICT_MODE=false


# ── OCR (optional — needed for PDF EOB/SOP parsing) ──────────────────────────
# Path to Tesseract binary
#   Linux: apt install tesseract-ocr
#   macOS: brew install tesseract
TESSERACT_CMD=/usr/bin/tesseract
OCR_DPI=300


# ── External adapter selection ────────────────────────────────────────────────
# Controls which adapter class is instantiated for each external system.
# Use 'mock' for development/testing (no real system credentials needed).
# Switch to a real adapter name when integrating with live systems.

# EMR/EHR adapter: mock | epic | cerner | athena | rpa_portal
EMR_ADAPTER=mock

# Practice Management System adapter: mock | kareo | advancedmd
PMS_ADAPTER=mock

# Payer data adapter: mock | availity | change_healthcare
PAYER_ADAPTER=mock

# Default payer submission adapter (overridden per-payer in payer_submission_registry):
# mock | availity_api | rpa_portal | edi_837
SUBMISSION_ADAPTER=mock


# ── Submission retry policy ───────────────────────────────────────────────────
# Number of retry attempts for transient submission failures (network/5xx)
SUBMISSION_MAX_RETRIES=3

# Initial delay between retries in seconds (exponential backoff: ×2 each retry)
SUBMISSION_RETRY_DELAY_SECONDS=5.0


# ── Batch processing ──────────────────────────────────────────────────────────
# Skip claims that already have a completed output package (idempotency)
SKIP_COMPLETED_CLAIMS=true

# Max concurrent claims (future use — currently always 1)
MAX_CONCURRENT_CLAIMS=1

BATCH_MAX_RETRIES=3
BATCH_RETRY_DELAY_SECONDS=2.0


# ── Database backend (Gap 48) ─────────────────────────────────────────────────
# Default: sqlite — zero config, works out of the box.
# Production: set to postgresql and provide DATABASE_URL.
#
# To switch:
#   1. Set DATABASE_TYPE=postgresql and DATABASE_URL below
#   2. Create schema: rcm-denial db export-schema | psql -d rcm_denial
#   3. Migrate data:  rcm-denial db migrate-to-postgres
DATABASE_TYPE=sqlite

# PostgreSQL connection URL (only used when DATABASE_TYPE=postgresql)
# Format: postgresql://user:password@host:5432/database_name
DATABASE_URL=


# ── Observability / Prometheus (Gap 44) ───────────────────────────────────────
# Automatically write data/metrics/rcm_denial.prom after each batch.
# Prometheus scrapes this via node_exporter textfile collector:
#   node_exporter --collector.textfile.directory=./data/metrics/
METRICS_EXPORT_AFTER_BATCH=true

# Prometheus Pushgateway URL — leave empty to disable push.
# Start stack: docker compose -f data/observability/docker-compose.yml up
PROMETHEUS_PUSHGATEWAY_URL=


# ── Web UI / Ports ────────────────────────────────────────────────────────────
# NiceGUI web UI port (also configurable via --port flag)
WEB_PORT=8080

# Grafana dashboard port (used in docker-compose)
GRAFANA_PORT=3000


# ── File paths ────────────────────────────────────────────────────────────────
OUTPUT_DIR=./output
LOG_DIR=./logs
LOG_LEVEL=INFO
DATA_DIR=./data


# ── AWS Textract (future integration — not used yet) ─────────────────────────
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=us-east-1
